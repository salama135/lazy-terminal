{
  "name": "lazy-terminal",
  "displayName": "lazy-terminal",
  "description": "an extension for lazy programmers that let's you click on the most used commands instead of typing them",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onTerminalShellIntegration"
],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lazy-terminal.helloWorld",
        "title": "Hello World"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "terminal-macro-container",
          "title": "Macro Bar",
          "icon": "$(terminal)"
        }
      ]
    },
    "views": {
      "terminal-macro-container": [
        {
          "type": "webview",
          "id": "terminalMacroBarView",
          "name": "Most Used Commands"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}